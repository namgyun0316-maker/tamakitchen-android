<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- 코너만 보이게: 전체는 투명 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

    <!-- 왼쪽 위 -->
    <item android:left="0dp" android:top="0dp">
        <shape android:shape="rectangle">
            <size android:width="34dp" android:height="34dp"/>
            <stroke android:width="3dp" android:color="#EFFFFFFF"/>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- 오른쪽 위 -->
    <item android:right="0dp" android:top="0dp" android:gravity="right">
        <shape android:shape="rectangle">
            <size android:width="34dp" android:height="34dp"/>
            <stroke android:width="3dp" android:color="#EFFFFFFF"/>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- 왼쪽 아래 -->
    <item android:left="0dp" android:bottom="0dp" android:gravity="bottom">
        <shape android:shape="rectangle">
            <size android:width="34dp" android:height="34dp"/>
            <stroke android:width="3dp" android:color="#EFFFFFFF"/>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

    <!-- 오른쪽 아래 -->
    <item android:right="0dp" android:bottom="0dp" android:gravity="right|bottom">
        <shape android:shape="rectangle">
            <size android:width="34dp" android:height="34dp"/>
            <stroke android:width="3dp" android:color="#EFFFFFFF"/>
            <solid android:color="@android:color/transparent"/>
            <corners android:radius="22dp"/>
        </shape>
    </item>

</layer-list>