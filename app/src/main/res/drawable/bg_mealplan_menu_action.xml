<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape>
            <solid android:color="#EEF7FD" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#D7ECF8" />
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#F8FBFE" />
            <corners android:radius="20dp" />
            <stroke
                android:width="1dp"
                android:color="#E6EEF5" />
        </shape>
    </item>
</selector>