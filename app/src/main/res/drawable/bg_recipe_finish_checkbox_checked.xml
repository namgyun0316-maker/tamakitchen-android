<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <item>
        <shape android:shape="rectangle">
            <solid android:color="#9FD3F2" />
            <corners android:radius="7dp" />
            <stroke
                android:width="1dp"
                android:color="#9FD3F2" />
            <size
                android:width="26dp"
                android:height="26dp" />
        </shape>
    </item>

    <item
        android:gravity="center"
        android:drawable="@drawable/ic_recipe_finish_check" />
</layer-list>