<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- 배경 -->
    <solid android:color="@android:color/white"/>

    <!-- 모서리 둥글게 -->
    <corners android:radius="22dp"/>

    <!-- 테두리 -->
    <stroke
        android:width="1dp"
        android:color="#E6E6E6"/>

    <!-- 내부 여백 -->
    <padding
        android:left="24dp"
        android:top="20dp"
        android:right="24dp"
        android:bottom="18dp"/>
</shape>
