<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="0dp"
    android:background="@android:color/transparent">

    <!-- ✅ 바깥 큰 사각형 제거: 카드 1개만 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_dialog_card"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="18dp">

        <!-- 타이틀 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="추방하기"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/calc_text_primary"
            android:fontFamily="@font/gmarket_sans_light"
            android:includeFontPadding="false" />

        <!-- 설명 -->
        <TextView
            android:id="@+id/tvDesc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="OOO님을 공동냉장고에서 추방할까?\n추방하면 다시 초대가 필요해."
            android:textSize="15sp"
            android:textColor="@color/gray_text_soft"
            android:fontFamily="@font/gmarket_sans_light"
            android:includeFontPadding="false"
            android:lineSpacingExtra="4dp" />

        <!-- 버튼 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="horizontal"
            android:gravity="end">

            <!-- 취소 -->
            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="취소"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/pascal_blue"
                android:fontFamily="@font/gmarket_sans_light"
                android:includeFontPadding="false"
                android:background="@android:color/transparent" />

            <!-- 간격 -->
            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <!-- 추방하기(위험 버튼) -->
            <TextView
                android:id="@+id/btnConfirm"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:gravity="center"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="추방하기"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#E53935"
                android:fontFamily="@font/gmarket_sans_light"
                android:includeFontPadding="false"
                android:background="@android:color/transparent" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
