<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:implementationMode="performance" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/overlayRoot"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- ✅ 우상단 X 닫기 -->
        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_marginTop="14dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_icon_circle"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:tint="@android:color/white"
            android:contentDescription="닫기"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- ✅ 상단 안내 카드 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/topCard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="14dp"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="18dp"
            app:cardElevation="10dp"
            app:cardBackgroundColor="#66FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="14dp"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvGuide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="영수증을 프레임 안에 맞춰주세요"
                    android:textColor="@color/calc_text_primary"
                    android:textStyle="bold"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=""
                    android:visibility="gone" />
            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- ✅ 하단 버튼 바 -->
        <LinearLayout
            android:id="@+id/bottomBar"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="36dp"
            android:paddingStart="0dp"
            android:paddingTop="10dp"
            android:paddingEnd="0dp"
            android:paddingBottom="10dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:background="@android:color/transparent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="취소"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="18dp"
                app:backgroundTint="#8A8A8A"
                app:elevation="2dp" />

            <Space
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_height="50dp"
                android:layout_weight="1"
                android:text="스캔 완료"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                app:cornerRadius="18dp"
                app:backgroundTint="@color/pascal_blue"
                app:elevation="2dp" />
        </LinearLayout>

        <!-- ✅ 하단 밴드: 좌측 도구 + 안내 텍스트 -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottomOverlay"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="16dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toTopOf="@id/bottomBar">

            <!-- 좌하단: 확대/손전등 -->
            <LinearLayout
                android:id="@+id/leftTools"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent">

                <ImageButton
                    android:id="@+id/btnZoom"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_icon_pill"
                    android:src="@drawable/ic_zoom_thin"
                    android:tint="@android:color/white"
                    android:contentDescription="확대" />

                <Space
                    android:layout_width="1dp"
                    android:layout_height="10dp" />

                <ImageButton
                    android:id="@+id/btnTorch"
                    android:layout_width="46dp"
                    android:layout_height="46dp"
                    android:background="@drawable/bg_icon_pill"
                    android:src="@drawable/ic_flashlight_outline"
                    android:scaleType="centerInside"
                    android:tint="@android:color/white"
                    android:contentDescription="손전등" />
            </LinearLayout>

            <!-- ✅ 안내 텍스트: "부드럽게 줄바꿈 + 안 잘림" 세팅 -->
            <TextView
                android:id="@+id/tvHint"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_hint_pill"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical"
                android:text="조금 어두워요. 손전등을 켜주시면 더 잘 인식돼요."
                android:textColor="@android:color/white"
                android:textSize="12sp"
                android:includeFontPadding="false"
                android:singleLine="true"
                android:maxLines="1"
                android:ellipsize="end"
                android:scrollHorizontally="true"
                app:layout_constraintStart_toEndOf="@id/leftTools"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent" />
        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- ✅ 가이드 프레임: bottomOverlay 위까지만 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/guideCard"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginStart="28dp"
            android:layout_marginEnd="28dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            app:strokeColor="#CCFFFFFF"
            app:strokeWidth="2dp"
            app:layout_constraintTop_toBottomOf="@id/topCard"
            app:layout_constraintBottom_toTopOf="@id/bottomOverlay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintDimensionRatio="3:5" />

        <!-- ✅ 스크림 4면 -->
        <View
            android:id="@+id/scrimTop"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/scanner_scrim_dark_soft"
            app:layout_constraintTop_toBottomOf="@id/topCard"
            app:layout_constraintBottom_toTopOf="@id/guideCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/scrimBottom"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/scanner_scrim_dark_soft"
            app:layout_constraintTop_toBottomOf="@id/guideCard"
            app:layout_constraintBottom_toTopOf="@id/bottomOverlay"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <View
            android:id="@+id/scrimLeft"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/scanner_scrim_dark_soft"
            app:layout_constraintTop_toTopOf="@id/guideCard"
            app:layout_constraintBottom_toBottomOf="@id/guideCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/guideCard" />

        <View
            android:id="@+id/scrimRight"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:background="@color/scanner_scrim_dark_soft"
            app:layout_constraintTop_toTopOf="@id/guideCard"
            app:layout_constraintBottom_toBottomOf="@id/guideCard"
            app:layout_constraintStart_toEndOf="@id/guideCard"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>