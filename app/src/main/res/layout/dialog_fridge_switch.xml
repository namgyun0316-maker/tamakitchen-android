<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/bg_dialog_fridge_switch">

    <TextView
        android:id="@+id/tv_dialog_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="냉장고 전환"
        android:textColor="#222222"
        android:textSize="22sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-black" />

    <TextView
        android:id="@+id/tv_dialog_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="사용할 냉장고를 선택해주세요"
        android:textColor="#8E96A3"
        android:textSize="13sp" />

    <LinearLayout
        android:id="@+id/layout_option_personal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:background="@drawable/bg_fridge_switch_option"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/iv_personal_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:tint="#7FC4F1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_personal_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="개인 냉장고"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_personal_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="나만 사용하는 냉장고"
                android:textColor="#97A0AE"
                android:textSize="12sp" />
        </LinearLayout>

        <RadioButton
            android:id="@+id/rb_personal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#7FC4F1"
            android:clickable="false"
            android:focusable="false" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layout_option_shared"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:background="@drawable/bg_fridge_switch_option"
        android:gravity="center_vertical"
        android:minHeight="72dp"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingTop="16dp"
        android:paddingEnd="18dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/iv_shared_icon"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@android:drawable/ic_menu_share"
            android:tint="#7FC4F1" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_shared_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="공동 냉장고"
                android:textColor="#222222"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_shared_desc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="가족·룸메이트와 함께 사용"
                android:textColor="#97A0AE"
                android:textSize="12sp" />
        </LinearLayout>

        <RadioButton
            android:id="@+id/rb_shared"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:buttonTint="#7FC4F1"
            android:clickable="false"
            android:focusable="false" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:gravity="end"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btn_close"
            android:layout_width="88dp"
            android:layout_height="48dp"
            android:gravity="center"
            android:text="닫기"
            android:textColor="#8EC9EF"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btn_switch"
            android:layout_width="88dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:gravity="center"
            android:text="전환"
            android:textColor="#8EC9EF"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

</LinearLayout>