<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/white"
        app:elevation="0dp"
        app:liftOnScroll="true">

        <com.google.android.material.appbar.CollapsingToolbarLayout
            android:id="@+id/collapsing"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            app:layout_scrollFlags="scroll|enterAlways"
            app:contentScrim="@android:color/white"
            app:scrimAnimationDuration="240">

            <LinearLayout
                android:id="@+id/headerContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@android:color/white"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingBottom="12dp"
                android:paddingTop="0dp"
                app:layout_collapseMode="pin">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tvRecipeTitle"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="레시피"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@android:color/black" />

                    <Button
                        android:id="@+id/btnAddRecipe"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="레시피 추가하기"
                        android:textSize="13sp"
                        android:textAllCaps="false"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp"
                        android:backgroundTint="#87CEEB"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_horizontal"
                    android:layout_marginBottom="6dp">

                    <Button
                        android:id="@+id/btnRecommend"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="냉장고 레시피"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#87CEEB"
                        android:textColor="@android:color/white" />

                    <View
                        android:layout_width="8dp"
                        android:layout_height="0dp" />

                    <Button
                        android:id="@+id/btnAll"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:text="전체 레시피"
                        android:textSize="14sp"
                        android:textAllCaps="false"
                        android:backgroundTint="#87CEEB"
                        android:textColor="@android:color/white" />
                </LinearLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilRecipeSearch"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"
                    android:hint="레시피 검색 (이름/요약/재료)"
                    app:startIconDrawable="@android:drawable/ic_menu_search"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="18dp"
                    app:boxCornerRadiusTopEnd="18dp"
                    app:boxCornerRadiusBottomStart="18dp"
                    app:boxCornerRadiusBottomEnd="18dp"
                    app:boxStrokeColor="#87CEEB"
                    app:boxStrokeWidth="1dp"
                    app:boxStrokeWidthFocused="2dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etRecipeSearch"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:scrollbars="none"
                    android:layout_marginBottom="8dp"
                    android:paddingEnd="12dp"
                    android:clipToPadding="false">

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/chipCuisineGroup"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:singleLine="true"
                        app:singleSelection="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineAll"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="전체"
                            android:checked="true" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineKorean"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="한식" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineJapanese"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="일식" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineChinese"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="중식" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineWestern"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="양식" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineDessert"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="디저트" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineDiet"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="다이어트" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipCuisineFavorite"
                            style="@style/RecipeCategoryChip"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="즐겨찾기" />

                    </com.google.android.material.chip.ChipGroup>
                </HorizontalScrollView>

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recipeRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/white"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <FrameLayout
        android:id="@+id/layoutRecipeLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="350dp"
        android:paddingBottom="80dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|center_horizontal"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="150dp"
                android:layout_height="150dp"
                android:background="@drawable/bg_recipe_loading_pet_circle">

                <ImageView
                    android:id="@+id/imgLoadingPet"
                    android:layout_width="118dp"
                    android:layout_height="118dp"
                    android:layout_gravity="center"
                    android:adjustViewBounds="true"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null" />

            </FrameLayout>

            <TextView
                android:id="@+id/tvRecipeLoadingText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="레시피를 불러오는 중..."
                android:textColor="#333333"
                android:textSize="16sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="냉장고 재료와 어울리는 요리를 찾고 있어요"
                android:textColor="#888888"
                android:textSize="13sp" />

        </LinearLayout>

    </FrameLayout>

    <TextView
        android:id="@+id/emptyRecipeText"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:text="등록된 레시피가 없습니다."
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#555555"
        android:gravity="center"
        android:paddingBottom="80dp"
        android:visibility="gone"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>