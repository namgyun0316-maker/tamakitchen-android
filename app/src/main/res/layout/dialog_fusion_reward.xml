<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:background="@drawable/bg_fusion_guide_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="28dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp">

    <FrameLayout
        android:layout_width="190dp"
        android:layout_height="170dp"
        android:layout_gravity="center_horizontal">

        <View
            android:id="@+id/viewRewardHalo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_gravity="center"
            android:background="@drawable/bg_fusion_reward_halo" />

        <ImageView
            android:id="@+id/ivFusionRewardCharacter"
            android:layout_width="132dp"
            android:layout_height="132dp"
            android:layout_gravity="center"
            android:scaleType="fitCenter" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvFusionRewardTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="딸기케이크"
        android:textColor="#202227"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFusionRewardMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineSpacingExtra="4dp"
        android:text="딸기케이크를 얻었습니다!"
        android:textColor="#4D5566"
        android:textSize="17sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnFusionRewardConfirm"
        android:layout_width="180dp"
        android:layout_height="48dp"
        android:layout_marginTop="24dp"
        android:text="확인"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#A9D4F5"
        app:cornerRadius="18dp"
        app:elevation="0dp"
        app:strokeColor="#00000000"
        app:strokeWidth="0dp" />

</LinearLayout>