<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="18dp"
    android:background="@android:color/transparent">

    <!-- ✅ 실제 다이얼로그 카드(둥근 모서리) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp"
        android:background="@drawable/bg_dialog_round_white">

        <!-- 상단 아이콘 + 텍스트 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <!-- ✅ 원형 아이콘 배경 -->
            <FrameLayout
                android:layout_width="86dp"
                android:layout_height="86dp"
                android:layout_marginTop="4dp"
                android:background="@drawable/bg_dialog_icon_circle"
                android:gravity="center">

                <ImageView
                    android:id="@+id/ivIcon"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_launcher_foreground"
                    android:scaleType="centerInside" />
            </FrameLayout>

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="재료삭제"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#2E3A4B"
                android:layout_marginTop="14dp" />

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="'양배추'"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#2E3A4B"
                android:layout_marginTop="8dp" />

            <TextView
                android:id="@+id/tvMessage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="정말 삭제하시겠습니까?\n삭제된 재료는 복구할 수 없습니다."
                android:textSize="14sp"
                android:textColor="#7A869A"
                android:gravity="center"
                android:layout_marginTop="12dp" />
        </LinearLayout>

        <!-- 하단 버튼 영역 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="22dp">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="취소"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#6B778C" />

            <TextView
                android:id="@+id/btnDelete"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:text="삭제"
                android:gravity="center"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#E74C3C" />
        </LinearLayout>

    </LinearLayout>

</LinearLayout>
