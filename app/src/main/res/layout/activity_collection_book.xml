<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F8FC"
    android:orientation="vertical"
    android:fitsSystemWindows="true">

    <!-- 상단 제목 -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/tvCollectionTitle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="도감"
            android:textColor="#202227"
            android:textSize="22sp"
            android:textStyle="bold" />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp">

        <TextView
            android:id="@+id/tvCollectionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|start"
            android:text="발견 0 / 0"
            android:textColor="#202227"
            android:textSize="16sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSellMode"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical|end"
            android:minWidth="86dp"
            android:text="판매하기"
            android:textAllCaps="false"
            android:textColor="#202227"
            android:textSize="14sp"
            app:backgroundTint="#FFE6A7"
            app:cornerRadius="18dp"
            app:icon="@drawable/ic_coin"
            app:iconGravity="textStart"
            app:iconPadding="4dp"
            app:iconSize="18dp"
            app:iconTint="@null"
            app:strokeWidth="0dp" />

    </FrameLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:fillViewport="false"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="20dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCategoryAll"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:minWidth="90dp"
                android:text="전체"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="#8CCFEF"
                app:cornerRadius="21dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCategoryIngredient"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:minWidth="108dp"
                android:text="재료"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="#8CCFEF"
                app:cornerRadius="21dp"
                app:strokeWidth="0dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnCategoryFood"
                android:layout_width="wrap_content"
                android:layout_height="42dp"
                android:layout_marginStart="10dp"
                android:minWidth="108dp"
                android:text="음식"
                android:textAllCaps="false"
                android:textSize="16sp"
                app:backgroundTint="#8CCFEF"
                app:cornerRadius="21dp"
                app:strokeWidth="0dp" />

        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCollection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="18dp" />

</LinearLayout>