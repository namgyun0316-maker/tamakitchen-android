<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white"
    android:fitsSystemWindows="true"
    android:paddingTop="12dp">

    <!-- 카테고리 탭 -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_categories"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="4dp"
        app:tabMode="scrollable"
        app:tabIndicatorColor="#87CEEB"
        app:tabSelectedTextColor="#2E3A4B"
        app:tabTextColor="#8A94A6"
        app:tabRippleColor="#1A87CEEB" />

    <!-- 검색창 -->
    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/text_input_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="12dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"
        app:hintEnabled="false"
        app:startIconDrawable="@android:drawable/ic_menu_search"
        app:startIconTint="#8A94A6"
        app:endIconMode="clear_text"
        app:endIconTint="#8A94A6"
        app:boxBackgroundMode="outline"
        app:boxCornerRadiusTopStart="18dp"
        app:boxCornerRadiusTopEnd="18dp"
        app:boxCornerRadiusBottomStart="18dp"
        app:boxCornerRadiusBottomEnd="18dp"
        app:boxStrokeColor="#D6DEE8"
        app:boxStrokeWidth="1dp"
        app:boxStrokeWidthFocused="2dp">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="상품명 검색"
            android:inputType="text"
            android:maxLines="1"
            android:padding="12dp" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- 아이콘 목록 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_icons"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:overScrollMode="never"
        android:paddingHorizontal="10dp"
        android:paddingBottom="10dp" />

    <!-- 선택된 아이템 입력 패널 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_selected_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="10dp"
        android:visibility="gone"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:strokeColor="#E6ECF3"
        app:strokeWidth="1dp"
        android:backgroundTint="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 핸들 -->
            <View
                android:layout_width="44dp"
                android:layout_height="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="12dp"
                android:background="@drawable/bg_panel_handle" />

            <!-- 아이콘 + 상품명 + (X 닫기 버튼) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginEnd="12dp"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E6ECF3"
                    android:backgroundTint="#F6FAFF">

                    <ImageView
                        android:id="@+id/iv_selected_product"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="10dp"
                        android:contentDescription="선택된 아이콘"
                        android:scaleType="centerInside" />
                </com.google.android.material.card.MaterialCardView>

                <EditText
                    android:id="@+id/et_selected_product"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#2E3A4B"
                    android:hint="상품명 입력"
                    android:textColorHint="#B0BAC9"
                    android:maxLines="1" />

                <!-- ✅ 오른쪽 상단 X 버튼 -->
                <ImageButton
                    android:id="@+id/btn_close_panel"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_circle_outline_light"
                    android:contentDescription="닫기"
                    android:scaleType="center"
                    android:padding="2dp"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#8A94A6" />


            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- 보관 방법 ChipGroup -->
            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chip_group_storage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:chipSpacingHorizontal="8dp">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_storage_fridge"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="냉장"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_storage_bg"
                    app:chipStrokeColor="@color/chip_storage_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/chip_storage_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_storage_freezer"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="냉동"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_storage_bg"
                    app:chipStrokeColor="@color/chip_storage_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/chip_storage_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_storage_room"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="실온"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_storage_bg"
                    app:chipStrokeColor="@color/chip_storage_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/chip_storage_text" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chip_storage_etc"
                    style="@style/Widget.MaterialComponents.Chip.Choice"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="기타"
                    app:checkedIconVisible="false"
                    app:chipBackgroundColor="@color/chip_storage_bg"
                    app:chipStrokeColor="@color/chip_storage_stroke"
                    app:chipStrokeWidth="1dp"
                    android:textColor="@color/chip_storage_text" />
            </com.google.android.material.chip.ChipGroup>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- 수량 + 단위 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:background="@drawable/bg_round_outline"
                    android:padding="8dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_decrease"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="-"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        app:cornerRadius="18dp"
                        app:strokeColor="#D6DEE8"
                        app:strokeWidth="1dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp" />

                    <TextView
                        android:id="@+id/tv_quantity"
                        android:layout_width="0dp"
                        android:layout_height="36dp"
                        android:layout_weight="1"
                        android:text="1"
                        android:gravity="center"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#2E3A4B" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_increase"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="36dp"
                        android:layout_height="36dp"
                        android:text="+"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        app:cornerRadius="18dp"
                        app:strokeColor="#D6DEE8"
                        app:strokeWidth="1dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:minWidth="0dp"
                        android:minHeight="0dp"
                        android:padding="0dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_unit"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginStart="10dp"
                    android:gravity="center"
                    android:paddingHorizontal="14dp"
                    android:text="개"
                    android:textStyle="bold"
                    android:textColor="#2E3A4B"
                    android:background="@drawable/bg_round_outline" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <!-- 유통기한 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="@drawable/bg_round_outline"
                android:padding="10dp">

                <EditText
                    android:id="@+id/et_expiry_date"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="유통기한 (선택)"
                    android:textColor="#2E3A4B"
                    android:textColorHint="#B0BAC9"
                    android:focusable="false"
                    android:clickable="true"
                    android:maxLines="1" />

                <ImageView
                    android:id="@+id/btn_calendar"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="달력"
                    android:src="@android:drawable/ic_menu_my_calendar"
                    android:tint="#8A94A6" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="12dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_direct_add"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="직접 추가하기"
                android:textStyle="bold"
                android:textColor="#2E3A4B"
                android:backgroundTint="#EEF2F7"
                app:cornerRadius="22dp" />

            <LinearLayout
                android:id="@+id/layout_add_button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:text="추가"
                    android:textStyle="bold"
                    android:textColor="@android:color/white"
                    app:cornerRadius="24dp"
                    android:enabled="false"
                    android:backgroundTint="#87CEEB" />
            </LinearLayout>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

</LinearLayout>
