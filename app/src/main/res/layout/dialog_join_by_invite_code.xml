<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardUseCompatPadding="true"
    app:cardElevation="10dp"
    app:cardCornerRadius="22dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="초대코드로 참여"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#2E3A4B" />

            <TextView
                android:id="@+id/btnClose"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#8A94A6"
                android:background="@drawable/bg_pill_outline_light" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="공유받은 초대코드를 입력해줘요."
            android:textSize="13sp"
            android:textColor="#8A94A6" />

        <EditText
            android:id="@+id/etInviteCode"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="14dp"
            android:hint="예: A1B2C3"
            android:singleLine="true"
            android:paddingHorizontal="14dp"
            android:background="@drawable/bg_input_outline"
            android:textColor="#2E3A4B"
            android:textColorHint="#B0BAC9" />

        <TextView
            android:id="@+id/btnPaste"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="클립보드에서 붙여넣기"
            android:textStyle="bold"
            android:textColor="#2E3A4B"
            android:background="@drawable/bg_btn_outline" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:id="@+id/btnCancel"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="취소"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#2E3A4B"
                android:background="@drawable/bg_btn_outline" />

            <View
                android:layout_width="10dp"
                android:layout_height="1dp" />

            <TextView
                android:id="@+id/btnJoin"
                android:layout_width="0dp"
                android:layout_height="52dp"
                android:layout_weight="1"
                android:gravity="center"
                android:text="참여"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@android:color/white"
                android:background="@drawable/bg_btn_primary" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="※ 대소문자는 구분하지 않아요."
            android:textSize="12sp"
            android:textColor="#8A94A6" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
