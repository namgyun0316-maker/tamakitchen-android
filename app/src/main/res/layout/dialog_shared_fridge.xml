<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardDialog"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="0dp"
    android:background="@android:color/transparent"
    app:cardUseCompatPadding="false"
    app:cardPreventCornerOverlap="true"
    app:cardElevation="10dp"
    app:cardCornerRadius="22dp"
    app:cardBackgroundColor="@android:color/white">

    <LinearLayout
        android:id="@+id/contentRoot"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="22dp"
        android:paddingEnd="22dp"
        android:paddingTop="22dp"
        android:paddingBottom="18dp">

        <!-- 헤더 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="공동 냉장고"
                android:textSize="19sp"
                android:textStyle="bold"
                android:textColor="#2E3A4B" />

            <!-- 닫기(X) -->
            <TextView
                android:id="@+id/btnClose"
                android:layout_width="34dp"
                android:layout_height="34dp"
                android:gravity="center"
                android:text="✕"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#8A94A6"
                android:background="@drawable/bg_pill_outline_light" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvSub"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="가족/룸메이트와 함께 재료를 관리해요.\n초대코드로 쉽게 참여할 수 있어요."
            android:textSize="13sp"
            android:textColor="#8A94A6"
            android:lineSpacingExtra="2dp" />

        <!-- 안내 박스 -->
        <LinearLayout
            android:id="@+id/boxInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical"
            android:padding="14dp"
            android:background="@drawable/bg_soft_info">

            <TextView
                android:id="@+id/tvInfoTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="이렇게 좋아요"
                android:textStyle="bold"
                android:textSize="13sp"
                android:textColor="#2E3A4B" />

            <TextView
                android:id="@+id/tvInfoBody"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="• 재료 중복 구매를 줄여요\n• 유통기한을 함께 관리해요\n• 레시피 추천이 더 정확해져요"
                android:textSize="13sp"
                android:textColor="#2E3A4B"
                android:lineSpacingExtra="2dp" />
        </LinearLayout>

        <!-- 버튼들 -->
        <TextView
            android:id="@+id/btnCreate"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="공동 냉장고 만들기"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/bg_btn_primary" />

        <TextView
            android:id="@+id/btnJoin"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:text="초대코드로 참여하기"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#2E3A4B"
            android:background="@drawable/bg_btn_outline" />

        <!-- ✅ 잘리던 문구: 여백 + 줄바꿈 안정화 -->
        <TextView
            android:id="@+id/tvHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingBottom="4dp"
            android:text="※ 초대코드는 일정 시간이 지나면 만료될 수 있어요."
            android:textSize="12sp"
            android:textColor="#8A94A6"
            android:lineSpacingExtra="2dp" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
