<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:padding="16dp">

    <!-- ================= 상단 헤더 ================= -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <!-- ✅ 타이틀: 동그라미(캡슐) 제거 + ▼ 유지 -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/titleContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            app:cardCornerRadius="0dp"
            app:cardElevation="0dp"
            app:strokeWidth="0dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:padding="0dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="냉장고"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:textColor="#2A2A2A"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/jua_regular" />

                <!-- ✅ ▼ 색을 + 버튼(FAB)과 동일하게 -->
                <TextView
                    android:id="@+id/tvTitleArrow"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="▾"
                    android:textSize="35sp"
                    android:textColor="#87CEEB"
                    android:includeFontPadding="false"
                    android:fontFamily="@font/jua_regular" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <ImageButton
            android:id="@+id/btn_options"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/options"
            android:contentDescription="설정"
            android:padding="8dp"
            android:scaleType="fitCenter" />
    </RelativeLayout>

    <!-- ================= 요약 ================= -->
    <TextView
        android:id="@+id/tv_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/layout_header"
        android:layout_marginTop="4dp"
        android:text="보관중 0개 · 임박 0개"
        android:textSize="14sp"
        android:textColor="@android:color/darker_gray"
        android:fontFamily="@font/jua_regular" />

    <!-- ================= 카테고리 (✅ 단일선택 + 균등분배는 코드로 width 세팅) ================= -->
    <com.google.android.material.chip.ChipGroup
        android:id="@+id/chip_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/tv_summary"
        android:layout_marginTop="12dp"
        app:singleSelection="true"
        app:selectionRequired="true"
        app:singleLine="true"
        app:chipSpacingHorizontal="10dp"
        app:chipSpacingVertical="0dp">

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_all"
            style="@style/FridgeCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="전체"
            android:checkable="true"
            android:checked="true"
            android:gravity="center"
            android:textAppearance="@style/ChipCuteText"
            android:textColor="@android:color/white"
            app:chipBackgroundColor="@color/sky_blue" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_fridge"
            style="@style/FridgeCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="냉장"
            android:checkable="true"
            android:gravity="center"
            android:textAppearance="@style/ChipCuteText"
            android:textColor="@android:color/white"
            app:chipBackgroundColor="@color/sky_blue" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_freezer"
            style="@style/FridgeCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="냉동"
            android:checkable="true"
            android:gravity="center"
            android:textAppearance="@style/ChipCuteText"
            android:textColor="@android:color/white"
            app:chipBackgroundColor="@color/sky_blue" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_room"
            style="@style/FridgeCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="실온"
            android:checkable="true"
            android:gravity="center"
            android:textAppearance="@style/ChipCuteText"
            android:textColor="@android:color/white"
            app:chipBackgroundColor="@color/sky_blue" />

        <com.google.android.material.chip.Chip
            android:id="@+id/chip_other"
            style="@style/FridgeCategoryChip"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="기타"
            android:checkable="true"
            android:gravity="center"
            android:textAppearance="@style/ChipCuteText"
            android:textColor="@android:color/white"
            app:chipBackgroundColor="@color/sky_blue" />

    </com.google.android.material.chip.ChipGroup>

    <!-- ================= 리스트 ================= -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_fridge_items"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_below="@id/chip_group"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="8dp"
        android:paddingBottom="96dp"
        android:clipToPadding="false" />

    <!-- ================= FAB (그림자 제거) ================= -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/btn_add_item"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="88dp"
        android:layout_marginEnd="0dp"
        app:backgroundTint="#87CEEB"
        app:tint="@android:color/white"
        app:srcCompat="@android:drawable/ic_input_add"
        app:elevation="0dp"
        app:pressedTranslationZ="0dp"
        android:stateListAnimator="@null" />

</RelativeLayout>