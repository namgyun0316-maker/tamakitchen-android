<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <!-- 뒤(흰색 아웃라인 느낌: shadow) -->
    <TextView
        android:id="@+id/tvTitleStroke"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        tools:text="개개개 공동냉장고"
        android:textSize="26sp"
        android:textStyle="bold"
        android:fontFamily="@font/gmarket_sans_light"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="22dp"
        android:shadowColor="@android:color/white"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="4"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 앞(파스칼블루) -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text=""
        tools:text="개개개 공동냉장고"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="@color/pascal_blue"
        android:fontFamily="@font/gmarket_sans_light"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginStart="18dp"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="22dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <!-- 공동냉장고 나가기 (타이틀 아래로 + 여백 더) -->
    <LinearLayout
        android:id="@+id/btnLeaveShared"
        android:layout_width="wrap_content"
        android:layout_height="42dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@drawable/bg_leave_pill"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:layout_marginEnd="18dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitle">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_exit_red"
            android:contentDescription="공동냉장고 나가기"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="공동냉장고 나가기"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#E53935"
            android:fontFamily="@font/gmarket_sans_light"
            android:includeFontPadding="false"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMembers"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="18dp"
        android:clipToPadding="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingBottom="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnLeaveShared"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_shared_member"/>
</androidx.constraintlayout.widget.ConstraintLayout>
