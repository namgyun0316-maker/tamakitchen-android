<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="24dp"
    android:layout_marginEnd="24dp"
    android:background="@drawable/bg_fusion_guide_dialog"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingTop="26dp"
    android:paddingEnd="24dp"
    android:paddingBottom="22dp">

    <TextView
        android:id="@+id/tvFusionGuideTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="합성할 수 있어!"
        android:textColor="#202227"
        android:textSize="22sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFusionGuideSubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:text="도우미 안내"
        android:textColor="#8D96A3"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvFusionGuideMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="22dp"
        android:gravity="center"
        android:includeFontPadding="false"
        android:lineSpacingExtra="4dp"
        android:text="LvMAX에 도달했어.\n합성 버튼을 누르면 다음 단계인 음식 캐릭터로 진화할 수 있어."
        android:textColor="#343840"
        android:textSize="17sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:gravity="center"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFusionGuideLater"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:minWidth="0dp"
            android:text="나중에"
            android:textAllCaps="false"
            android:textColor="#5A6472"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#EEF2F7"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:strokeColor="#00000000"
            app:strokeWidth="0dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnFusionGuideMove"
            android:layout_width="160dp"
            android:layout_height="48dp"
            android:layout_marginStart="10dp"
            android:minWidth="0dp"
            android:text="합성하러 가기"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            app:backgroundTint="#A9D4F5"
            app:cornerRadius="18dp"
            app:elevation="0dp"
            app:strokeColor="#00000000"
            app:strokeWidth="0dp" />

    </LinearLayout>

</LinearLayout>