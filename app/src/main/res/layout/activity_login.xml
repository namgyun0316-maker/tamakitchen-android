<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/login_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFF8EC">

    <ScrollView
        android:id="@+id/login_main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:background="#FFF8EC"
        tools:context=".ui.auth.LoginActivity">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:paddingStart="26dp"
            android:paddingTop="36dp"
            android:paddingEnd="26dp"
            android:paddingBottom="30dp">

            <ImageView
                android:id="@+id/imgFridge"
                android:layout_width="320dp"
                android:layout_height="320dp"
                android:layout_marginTop="0dp"
                android:adjustViewBounds="true"
                android:background="#FFF8EC"
                android:contentDescription="@string/app_name"
                android:cropToPadding="false"
                android:padding="-8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/tamakitchen_logo" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#FFFDF8"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:strokeColor="#F0DFC4"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:paddingStart="22dp"
                    android:paddingTop="24dp"
                    android:paddingEnd="22dp"
                    android:paddingBottom="24dp">

                    <TextView
                        android:id="@+id/tvSocialTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="간편하게 시작하기"
                        android:textColor="#6F563E"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="22dp"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btn_naver_login"
                            android:layout_width="62dp"
                            android:layout_height="62dp"
                            android:background="#FFFFFF"
                            android:clickable="true"
                            android:contentDescription="@string/naver_login"
                            android:focusable="true"
                            android:padding="10dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/naver_login"
                            app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                            app:strokeColor="#EADBC6"
                            app:strokeWidth="1dp" />

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btn_kakao_login"
                            android:layout_width="62dp"
                            android:layout_height="62dp"
                            android:background="#FFFFFF"
                            android:clickable="true"
                            android:contentDescription="@string/kakao_login"
                            android:focusable="true"
                            android:padding="10dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/kakao_login"
                            app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                            app:strokeColor="#EADBC6"
                            app:strokeWidth="1dp" />

                        <View
                            android:layout_width="18dp"
                            android:layout_height="1dp" />

                        <com.google.android.material.imageview.ShapeableImageView
                            android:id="@+id/btn_google_login"
                            android:layout_width="62dp"
                            android:layout_height="62dp"
                            android:background="#FFFFFF"
                            android:clickable="true"
                            android:contentDescription="@string/google_login"
                            android:focusable="true"
                            android:padding="10dp"
                            android:scaleType="fitCenter"
                            android:src="@drawable/google_login"
                            app:shapeAppearanceOverlay="@style/RoundedImageStyle"
                            app:strokeColor="#EADBC6"
                            app:strokeWidth="1dp" />

                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnGuest"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="26dp"
                        android:clickable="true"
                        android:enabled="true"
                        android:focusable="true"
                        android:text="비회원으로 둘러보기"
                        android:textAllCaps="false"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="#8A6A4E"
                        app:cornerRadius="20dp"
                        app:elevation="0dp"
                        app:strokeWidth="0dp" />

                    <TextView
                        android:id="@+id/tvGuestHint"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center"
                        android:includeFontPadding="false"
                        android:text="비회원은 일부 기능이 제한될 수 있어요."
                        android:textColor="#A89988"
                        android:textSize="13sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </ScrollView>

    <FrameLayout
        android:id="@+id/layoutLoginLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp"
            android:background="@drawable/bg_dialog_white_round">

            <ProgressBar
                android:layout_width="42dp"
                android:layout_height="42dp" />

            <TextView
                android:id="@+id/tvLoginLoading"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="로그인 중..."
                android:textColor="#333333"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>